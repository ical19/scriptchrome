    async function requestClaimDetail(vinInfo) {
        if (!capturedAuthorization) {
            scanStorageForToken();
        }

        if (!capturedAuthorization) {
            throw new Error('Authorization belum ditemukan. Pastikan halaman sudah login dan ada request API aktif dari aplikasi.');
        }

        const body = buildRequestBody(vinInfo);

        const response = await fetch(API_URL, {
            method: 'POST',
            mode: 'cors',
            credentials: 'include',
            referrer: 'https://passport.toyota.astra.co.id:5004/',
            headers: {
                accept: 'application/json, text/plain, */*',
                'content-type': 'application/json',
                authorization: capturedAuthorization
            },
            body: JSON.stringify(body)
        });

        const text = await response.text();
        recordResponseSize(text);

        let json;
        try {
            json = JSON.parse(text);
        } catch (_) {
            throw new Error(`Response bukan JSON. HTTP ${response.status}. Body: ${text.slice(0, 300)}`);
        }

        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${json.message || json.detail || 'Request gagal'}`);
        }

        return json;
    }

    async function requestClaimDetailWithFallback(vinInfo) {
        const attemptedKeys = new Set();
        let firstError = null;
        let firstJson = null;

        if (!vinInfo.needsVdsLookup) {
            try {
                attemptedKeys.add(getVINInfoKey(vinInfo));
                firstJson = await requestClaimDetail(vinInfo);

                if (hasClaimDetailData(firstJson)) {
                    return {
                        json: firstJson,
                        vinInfo,
                        usedFallback: false
                    };
                }

                logTerminal(
                    `Data belum ditemukan dengan split awal (${formatVINInfoSplit(vinInfo)}). Cek kandidat VDS...`,
                    'warn'
                );
            } catch (err) {
                firstError = err;

                if (isAuthorizationError(err)) {
                    throw err;
                }

                logTerminal(
                    `Request split awal gagal (${formatVINInfoSplit(vinInfo)}): ${err.message}. Cek kandidat VDS...`,
                    'warn'
                );
            }
        } else {
            logTerminal(`VIN ${vinInfo.vin} akan dicek memakai lookup VDS karena format awal tidak standar.`, 'warn');
        }

        const candidates = await resolveVINCandidates(vinInfo);
        const candidateLabels = [];

        for (const candidate of candidates) {
            const key = getVINInfoKey(candidate);
            if (attemptedKeys.has(key)) continue;

            attemptedKeys.add(key);
            candidateLabels.push(formatVINInfoSplit(candidate));
            logTerminal(`Coba kandidat VDS: ${formatVINInfoSplit(candidate)}`, 'info');

            try {
                const json = await requestClaimDetail(candidate);

                if (hasClaimDetailData(json)) {
                    logTerminal(`Split VIN berhasil: ${formatVINInfoSplit(candidate)}`, 'success');
                    return {
                        json,
                        vinInfo: candidate,
                        usedFallback: true
                    };
                }
            } catch (err) {
                if (isAuthorizationError(err)) {
                    throw err;
                }

                logTerminal(`Kandidat gagal (${formatVINInfoSplit(candidate)}): ${err.message}`, 'warn');
            }
        }

        if (firstJson && hasClaimDetailData(firstJson)) {
            return {
                json: firstJson,
                vinInfo,
                usedFallback: false
            };
        }

        const suffix = candidateLabels.length
        ? ` Kandidat dicoba: ${candidateLabels.join(' ; ')}.`
      : ' Tidak ada kandidat VDS yang cocok.';

        throw new Error(`Data VIN tidak ditemukan setelah cek VDS.${suffix}${firstError ? ' Error awal: ' + firstError.message : ''}`);
    }

