    function downloadExcel(headers, rows, filenamePrefix) {
        const normalizedHeaders = headers.map(header => typeof header === 'string' ? { label: header, key: header } : header);
        const html = `<!doctype html><html><head><meta charset="utf-8"><style>
          table{border-collapse:collapse;font-family:Calibri,Arial,sans-serif;font-size:12px}th,td{border:1px solid #d9e2f3;padding:6px 8px;white-space:nowrap}th{background:#1f4e78;color:#fff;font-weight:700;text-align:center}tr:nth-child(even) td{background:#eef5ff}.colRemain{background:#fff2cc;font-weight:700;text-align:center}.colUntil{background:#e2f0d9;text-align:center}.statusFree{background:#c6efce;color:#006100;font-weight:700;text-align:center}.statusPaid{background:#ffc7ce;color:#9c0006;font-weight:700;text-align:center}.vin{color:#0563c1;font-weight:700}.serviceOk{background:#c6efce;color:#006100;font-weight:700;text-align:center}.serviceEmpty{background:#fce4d6;color:#9c0006;text-align:center}
        </style></head><body><table><thead><tr>${normalizedHeaders.map(header => `<th>${escapeHtml(header.label)}</th>`).join('')}</tr></thead><tbody>${rows.map(row => `<tr>${normalizedHeaders.map(header => {
            const value = formatCSVValue(header, row[header.key] ?? '');
            const key = String(header.key || '');
            let cls = '';
            if (key === 'vin') cls = 'vin';
            if (key === 'remainingFree') cls = 'colRemain';
            if (key === 'freeUntil') cls = 'colUntil';
            if (key === 'freeStatus') cls = String(value).toUpperCase() === 'FREE' ? 'statusFree' : 'statusPaid';
            if (key.startsWith('service')) cls = String(value) === '-' ? 'serviceEmpty' : 'serviceOk';
            return `<td class="${cls}">${escapeHtml(value)}</td>`;
        }).join('')}</tr>`).join('')}</tbody></table></body></html>`;

        const blob = new Blob(['\uFEFF' + html], { type: 'application/vnd.ms-excel;charset=utf-8;' });
        triggerDownload(blob, filenamePrefix, 'xls');
    }

    function downloadCSV(headers, rows, filenamePrefix) {
        const normalizedHeaders = headers.map(header => {
            if (typeof header === 'string') {
                return { label: header, key: header };
            }

            return header;
        });

        const csv = [
            normalizedHeaders.map(header => header.label).join(','),
            ...rows.map(row => {
                return normalizedHeaders.map(header => csvEscape(formatCSVValue(header, row[header.key] ?? ''))).join(',');
            })
        ].join('\r\n');

        const blob = new Blob(['\uFEFF' + csv], {
            type: 'text/csv;charset=utf-8;'
        });

        triggerDownload(blob, filenamePrefix, 'csv');
    }

    function triggerDownload(blob, filenamePrefix, extension) {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');

        const ts = new Date()
        .toISOString()
        .replace(/[:.]/g, '-')
        .slice(0, 19);

        a.href = url;
        a.download = `${filenamePrefix}-${ts}.${extension}`;
        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    }

    /************************************************************
   * HELPERS
   ************************************************************/
    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function csvEscape(value) {
        const str = String(value ?? '');
        return `"${str.replaceAll('"', '""')}"`;
    }

    function formatCSVValue(header, value) {
        const key = String(header?.key || '').toLowerCase();
        const label = String(header?.label || '').toLowerCase();

        if (key.includes('date') || label.includes('date') || key.includes('completion')) {
            return formatDate(value);
        }

        return value;
    }

    function formatDate(value) {
        if (value === null || value === undefined || value === '') return '';

        if (value instanceof Date && !Number.isNaN(value.getTime())) {
            return formatDateParts(value.getFullYear(), value.getMonth() + 1, value.getDate());
        }

        const str = String(value).trim();
        const isoMatch = str.match(/^(\d{4})-(\d{2})-(\d{2})(?:[T\s].*)?$/);

        if (isoMatch) {
            return `${isoMatch[3]}-${isoMatch[2]}-${isoMatch[1]}`;
        }

        const compactMatch = str.match(/^(\d{4})\/(\d{2})\/(\d{2})(?:[T\s].*)?$/);

        if (compactMatch) {
            return `${compactMatch[3]}-${compactMatch[2]}-${compactMatch[1]}`;
        }

        return str;
    }

    function parseDisplayDate(value) {
        const formatted = formatDate(value);
        const match = String(formatted || '').trim().match(/^(\d{2})-(\d{2})-(\d{4})$/);
        if (!match) return null;
        const date = new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]));
        if (Number.isNaN(date.getTime())) return null;
        date.setHours(0, 0, 0, 0);
        return date;
    }

    function formatDateParts(year, month, day) {
        return [
            String(day).padStart(2, '0'),
            String(month).padStart(2, '0'),
            String(year)
        ].join('-');
    }

    function displayValue(value) {
        if (value === null || value === undefined || value === '') return '-';
        if (typeof value === 'boolean') return value ? 'true' : 'false';
        return String(value);
    }

    function toMultiline(value) {
        return String(value ?? '').replaceAll(' | ', '\n');
    }

