   * FORMAT1 DETAIL
   ************************************************************/
    function normalizeAndStoreDetailFormat(vin, json) {
        const item1 = json?.data?.item1 || {};
        const item2 = json?.data?.item2;

        if (Array.isArray(item2) && item2.length > 0) {
            for (const claim of item2) {
