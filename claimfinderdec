    async function resolveVINCandidates(vinInfo) {
        const vin = vinInfo.vin;
        const candidates = [];

        function add(candidate) {
            if (!candidate) return;
            if (!candidate.wmi || !candidate.vds || candidate.vis.length !== 8) return;
            if (candidates.some(item => getVINInfoKey(item) === getVINInfoKey(candidate))) return;
            candidates.push(candidate);
