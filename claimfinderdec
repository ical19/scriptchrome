    function normalizeVIN(raw) {
        return String(raw || '')
            .trim()
            .toUpperCase()
            .replace(/[^A-Z0-9]/g, '');
    }

    function parseVIN(raw) {
        const vin = normalizeVIN(raw);

        if (!vin) {
            throw new Error('VIN kosong');
        }

        if (vin.length !== 17) {
            throw new Error(`VIN harus 17 karakter. Diterima ${vin.length}: ${vin}`);
        }

        return buildStandardVINInfo(vin);
    }

    function buildStandardVINInfo(vin) {
        return {
            vin,
            wmi: vin.substring(0, 3),
            vds: vin.substring(3, 8),
            cd: vin.substring(8, 9),
            vis: vin.substring(9, 17)
        };
    }

    function buildLooseVINInfo(vin, reason = '') {
        return {
            vin,
            wmi: vin.substring(0, 3),
            vds: '',
            cd: '',
            vis: '',
            needsVdsLookup: true,
            parseReason: reason
        };
    }

    function canAttemptVdsLookup(vin) {
        return vin.length >= 11 && vin.length <= 18 && vin.substring(0, 3).length === 3;
    }

    function buildRequestBody(vinInfo) {
