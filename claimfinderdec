    /************************************************************
   * MRA SINGLE VIN CHECK
   ************************************************************/
    async function runMraCheck() {
        if (isMraRunning) {
            logTerminal('[MRA] Request masih berjalan.', 'warn');
            return;
        }

        const input = document.getElementById('tmVinInput').value;
        const firstLine = input
        .split(/\r?\n/)
        .map(x => x.trim())
        .find(Boolean);

        if (!firstLine) {
            logTerminal('[MRA] ERROR: Input nomor rangka masih kosong.', 'error');
            switchTab('terminal');
            return;
        }

        let vinInfo;
        try {
            vinInfo = parseVIN(firstLine);
        } catch (err) {
            logTerminal(`[MRA] ERROR: VIN pertama tidak valid. ${err.message}`, 'error');
            switchTab('terminal');
            return;
        }

        if (!capturedAuthorization) {
            scanStorageForToken();
        }

        if (!capturedAuthorization) {
            logTerminal('[MRA] ERROR: Authorization belum ditemukan. Pastikan halaman sudah login dan ada request API aktif dari aplikasi.', 'error');
            switchTab('terminal');
            return;
        }

        isMraRunning = true;
        switchTab('terminal');
        logTerminal(`[MRA] Ambil VIN pertama dari input: ${vinInfo.vin}`, 'info');
        logTerminal('[MRA] Request detail...', 'info');

        try {
            const json = await requestClaimDetail(vinInfo);
            const item2 = Array.isArray(json?.data?.item2) ? json.data.item2 : [];
            const summary = getMraFreeSummary(item2);

            logTerminal(
                `[MRA] Response OK. item2: ${summary.totalClaims}, free claimed: ${summary.claimCount}, remaining free: ${summary.remainingFree}.`,
                'success'
            );

            renderMraDetail(vinInfo.vin, json);
            switchTab('hasil');
            logTerminal('[MRA] Render detail selesai.', 'success');
        } catch (err) {
            logTerminal(`[MRA] ERROR: ${err.message}`, 'error');
        } finally {
            isMraRunning = false;
        }
    }

    /************************************************************
   * PROCESS CONTROL
   ************************************************************/
    async function startProcess() {
        if (isRunning) {
            logTerminal('Proses masih berjalan. Gunakan Pause atau Stop terlebih dahulu.', 'warn');
            return;
        }

        const lines = getVinInputLines();

        if (!lines.length) {
            logTerminal('Input nomor rangka masih kosong.', 'warn');
            return;
        }

        queue = [];
        retryErrorQueue = [];
        mainResults = [];
        detailResults = [];
        summaryResults = [];
        currentIndex = 0;
        shouldStop = false;
        isPaused = false;
        isRunning = true;
        resetProgressMetrics();

        clearTable();

        for (const line of lines) {
            try {
                queue.push(parseVIN(line));
            } catch (err) {
                const invalidVin = normalizeVIN(line);

                if (canAttemptVdsLookup(invalidVin)) {
                    queue.push(buildLooseVINInfo(invalidVin, err.message));
                    logTerminal(`VIN tidak standar akan dicek via lookup VDS: ${invalidVin} | ${err.message}`, 'warn');
                    continue;
                }

                logTerminal(`VIN invalid dilewati: ${line.trim()} | ${err.message}`, 'error');

                summaryResults.push({
                    no: summaryResults.length + 1,
                    vin: invalidVin || line.trim(),
                    claimCount: '',
                    remainingFree: '',
                    modelCode: '',
                    modelName: '',
                    epCodeDealer: '',
                    deliveryDate: '',
                    claimType: '',
                    repairDate: '',
                    mainOperationNo: '',
                    status: 'INVALID VIN',
                    error: err.message
                });

                pushMainEmptyRow(invalidVin || line.trim());
            }
        }

        renderMainResults();

        if (!queue.length) {
            isRunning = false;
            logTerminal('Tidak ada VIN valid untuk diproses.', 'error');
            updateProgress();
            return;
        }

        switchTab('terminal');
        logTerminal(`Mulai proses ${queue.length} nomor rangka valid.`, 'success');
        startProgressTimer();
        updateProgress();

        await processQueue();
    }

    function pauseProcess() {
        if (!isRunning) return;
        isPaused = true;
        logTerminal('Proses dijeda.', 'warn');
    }

    function continueProcess() {
        if (!isRunning) {
            logTerminal('Tidak ada proses berjalan untuk dilanjutkan.', 'warn');
            return;
        }

        if (!isPaused) {
            logTerminal('Proses tidak sedang pause.', 'warn');
            return;
        }

        isPaused = false;
        logTerminal('Proses dilanjutkan.', 'success');
    }

    async function retryErrorProcess() {
        if (isRunning) {
            logTerminal('Proses masih berjalan. Tunggu selesai sebelum retry error.', 'warn');
            return;
        }

        if (!retryErrorQueue.length) {
            logTerminal('Tidak ada VIN error / tidak ditemukan untuk diulang.', 'warn');
            return;
        }

        queue = retryErrorQueue.slice();
        retryErrorQueue = [];
        currentIndex = 0;
        shouldStop = false;
        isPaused = false;
        isRunning = true;
        resetProgressMetrics();

        switchTab('terminal');
        logTerminal(`Retry hanya VIN error / tidak ditemukan. Total: ${queue.length}.`, 'warn');
        startProgressTimer();
        updateProgress();

        await processQueue();
    }

    function addRetryErrorVIN(vinInfo) {
        const key = getVINInfoKey(vinInfo);
        const exists = retryErrorQueue.some(item => getVINInfoKey(item) === key);
        if (!exists) retryErrorQueue.push({ ...vinInfo });
    }

    function stopProcess() {
        if (!isRunning) {
            logTerminal('Tidak ada proses berjalan.', 'warn');
            return;
        }

        shouldStop = true;
        isPaused = false;
        logTerminal('Stop diminta. Proses akan berhenti setelah request aktif selesai.', 'warn');
    }

    async function processQueue() {
        while (currentIndex < queue.length) {
            if (shouldStop) {
                logTerminal('Proses dihentikan oleh user.', 'warn');
                break;
            }

            while (isPaused) {
                await sleep(250);
            }

            const vinInfo = queue[currentIndex];
            const rowNo = currentIndex + 1;
            const vinStartedAt = Date.now();
            activeVinStartedAt = vinStartedAt;

            logTerminal(
                `[${rowNo}/${queue.length}] Request VIN ${vinInfo.vin} | wmi=${vinInfo.wmi}, vds=${vinInfo.vds}, cd=${vinInfo.cd}, vis=${vinInfo.vis}`,
                'info'
            );
            updateProgress();

            try {
                const result = await requestClaimDetailWithFallback(vinInfo);
                const json = result.json;
                const resolvedVinInfo = result.vinInfo;

                normalizeAndStoreMainFormat(resolvedVinInfo.vin, json);
                normalizeAndStoreDetailFormat(resolvedVinInfo.vin, json);
                normalizeAndStoreSummaryFormat(resolvedVinInfo.vin, json);

                const item2 = Array.isArray(json?.data?.item2) ? json.data.item2 : [];
                const item2Count = item2.length;
                const claimCount = countFreeClaims(item2);
                const freeSummary = calculateFreeServiceSummary(item2, json?.data?.item1 || {});
                const remainingFree = freeSummary.remainingFree;
                const claimedOps = getClaimedFreeOperations(item2).join(', ') || '-';

                logTerminal(
                    `[${rowNo}/${queue.length}] OK ${resolvedVinInfo.vin}. item2: ${item2Count}, free claimed: ${claimCount}, sisa free: ${remainingFree}, op: ${claimedOps}.`,
                    'success'
                );

                if (result.usedFallback) {
                    logTerminal(`[${rowNo}/${queue.length}] Split final ${formatVINInfoSplit(resolvedVinInfo)}.`, 'success');
                }
            } catch (err) {
                logTerminal(`[${rowNo}/${queue.length}] ERROR ${vinInfo.vin}: ${err.message}`, 'error');

                summaryResults.push({
                    no: summaryResults.length + 1,
                    vin: vinInfo.vin,
                    claimCount: '',
                    remainingFree: '',
                    modelCode: '',
                    modelName: '',
                    epCodeDealer: '',
                    deliveryDate: '',
                    claimType: '',
                    repairDate: '',
                    mainOperationNo: '',
                    status: 'ERROR',
                    error: err.message
                });

                pushMainErrorRow(vinInfo.vin, err.message);
                addRetryErrorVIN(vinInfo);

                detailResults.push({
                    no: detailResults.length + 1,
                    vin: vinInfo.vin,
                    modelCode: '',
                    modelName: '',
                    epCodeDealer: '',
                    claimType: '',
                    deliveryDate: '',
                    repairDate: '',
                    km: '',
                    mainOperationNo: '',
                    condition: '',
                    serviceNo: '',
                    status: 'ERROR',
                    error: err.message
                });
            }

            vinDurations.push(Date.now() - vinStartedAt);
            activeVinStartedAt = 0;
            currentIndex++;
            renderMainResults();
            updateProgress();

            if (currentIndex < queue.length) {
                await sleep(REQUEST_DELAY_MS);
            }
        }

        isRunning = false;
        isPaused = false;
        activeVinStartedAt = 0;
        stopProgressTimer();

        updateProgress();
        switchTab('hasil');

        if (shouldStop) {
            logTerminal(`Selesai sebagian. Diproses ${currentIndex}/${queue.length}.`, 'warn');
        } else {
            logTerminal(`Selesai. Total VIN diproses: ${queue.length}. Total baris Format Utama: ${mainResults.length}.`, 'success');
        }
    }

    /************************************************************
   * FORMAT UTAMA
   ************************************************************/
    function normalizeAndStoreMainFormat(vin, json) {
        const item1 = json?.data?.item1 || {};
        const item2 = Array.isArray(json?.data?.item2) ? json.data.item2 : [];
        const row = createMainRow(vin, item1, item2);
        applyFreeServiceSummary(row, item2, item1);

        for (const claim of item2) {
            const operation = normalizeMainServiceOperation(claim?.mainOperationNo);
            if (!operation) continue;

            const repairDateKey = `repairDate${operation}`;
            const serviceKey = `service${operation}`;
            const repairDate = formatDate(claim?.repairDate) || '-';
            const epCodeDealer = String(claim?.epCodeDealer ?? '').trim() || '-';

            row[repairDateKey] = repairDate;
            row[serviceKey] = epCodeDealer;
            row[`branch${operation}`] = getBranchNameByDealerCode(epCodeDealer);
        }

        upsertMainRow(row);
    }

    function createMainRow(vin, item1 = {}, item2 = []) {
        const row = {
            no: mainResults.length + 1,
            vin,
            deliveryDate: formatDate(firstNonEmpty(item2.map(x => x.deliveryDate)) || item1.deliveryDate || ''),
            modelCode: item1.modelCode || '',
            modelName: item1.modelName || '',
            remainingFree: '-',
            freeUntil: '-',
            freeStatus: '-'
        };

        for (const operation of MAIN_SERVICE_OPERATIONS) {
            row[`repairDate${operation}`] = '-';
            row[`service${operation}`] = '-';
            row[`branch${operation}`] = '-';
        }

        return row;
    }

    function pushMainEmptyRow(vin) {
        upsertMainRow(createMainRow(vin));
    }

    function pushMainErrorRow(vin, errorMessage = '') {
        const row = createMainRow(vin);
        row.freeStatus = 'ERROR';
        row.error = errorMessage;
        upsertMainRow(row);
    }

    function upsertMainRow(row) {
        const key = normalizeVIN(row.vin);
        const existingIndex = mainResults.findIndex(item => normalizeVIN(item.vin) === key);

        if (existingIndex >= 0) {
            row.no = mainResults[existingIndex].no;
            mainResults[existingIndex] = row;
            return;
        }

        row.no = mainResults.length + 1;
        mainResults.push(row);
    }

    function normalizeMainServiceOperation(value) {
        const match = String(value ?? '')
        .trim()
        .toUpperCase()
        .match(/^(\d+)K$/);

        if (!match) return '';

        const operation = `${match[1]}K`;
        return MAIN_SERVICE_OPERATIONS.includes(operation) ? operation : '';
    }

    function getBranchNameByDealerCode(code) {
        const normalizedCode = String(code || '').trim().toUpperCase();
        if (!normalizedCode || normalizedCode === '-') return '-';
        return DEALER_BRANCH_MAP[normalizedCode] || '-';
    }

    function renderBranchCell(row, operation) {
        if (!showBranchColumns) return '';
        return `<td class="tmBranchCell">${escapeHtml(displayValue(row[`branch${operation}`]))}</td>`;
    }

