                    km: claim.km ?? '',
                    mainOperationNo: claim.mainOperationNo || '',
                    condition: claim.condition || '',
                    serviceNo: claim.serviceNo ?? '',
                    status: json?.message || 'OK',
                    error: ''
                });
            }
        } else {
            detailResults.push({
                no: detailResults.length + 1,
                vin,
                modelCode: item1.modelCode || '',
                modelName: item1.modelName || '',
                epCodeDealer: '',
                claimType: item1.claimType || '',
                deliveryDate: '',
                repairDate: '',
                km: '',
                mainOperationNo: '',
                condition: '',
                serviceNo: '',
                status: 'OK - item2 kosong',
                error: ''
            });
        }
    }

    /************************************************************
   * FORMAT2 SUMMARY
   ************************************************************/
    function normalizeAndStoreSummaryFormat(vin, json) {
        const item1 = json?.data?.item1 || {};
        const item2 = Array.isArray(json?.data?.item2) ? json.data.item2 : [];

        const claimCount = countFreeClaims(item2);
        const freeSummary = calculateFreeServiceSummary(item2, item1);
        const remainingFree = freeSummary.remainingFree;

        const epCodeDealerList = item2.map(x => x.epCodeDealer || '').filter(Boolean);
        const claimTypeList = item2.map(x => x.claimType || '').filter(Boolean);
        const repairDateList = item2.map(x => formatDate(x.repairDate) || '').filter(Boolean);
        const mainOperationList = item2.map(x => x.mainOperationNo || '').filter(Boolean);

        const deliveryDate = formatDate(firstNonEmpty(item2.map(x => x.deliveryDate)) || '');

        summaryResults.push({
            no: summaryResults.length + 1,
            vin,
            claimCount,
            remainingFree,
            freeUntil: freeSummary.freeUntil,
            freeStatus: freeSummary.freeStatus,
            modelCode: item1.modelCode || '',
            modelName: item1.modelName || '',
            epCodeDealer: joinMulti(epCodeDealerList),
            deliveryDate,
            claimType: joinMulti(claimTypeList),
            repairDate: joinMulti(repairDateList),
            mainOperationNo: joinMulti(mainOperationList),
            status: json?.message || 'OK',
            error: ''
        });
    }

    /************************************************************
   * HITUNG FREE CLAIM BERDASARKAN mainOperationNo
   ************************************************************/
    function getClaimedFreeOperations(item2) {
        if (!Array.isArray(item2)) return [];

        const claimedOperations = new Set();

        for (const item of item2) {
            const operation = String(item?.mainOperationNo || '')
            .trim()
            .toLowerCase();

            // Hanya hitung yang formatnya angka lalu huruf k.
            // Dihitung: 10000k, 20000k, 30000k
            // Tidak dihitung: 10000B, 20000b, 642991, YHG14A
            const match = operation.match(/^(\d+)k$/);

            if (match) {
                claimedOperations.add(match[1] + 'k');
            }
        }

        return Array.from(claimedOperations).sort((a, b) => {
            const na = Number(a.replace(/\D/g, ''));
            const nb = Number(b.replace(/\D/g, ''));
            return na - nb;
        });
    }

    function countFreeClaims(item2) {
        return getClaimedFreeOperations(item2).length;
    }

    function calculateFreeServiceSummary(item2, item1 = {}) {
        const claimedOps = getClaimedFreeOperations(item2);
        const claimedIndexes = claimedOps
            .map(op => MAIN_SERVICE_OPERATIONS.indexOf(op.toUpperCase()))
            .filter(index => index >= 0);
        const lastClaimIndex = claimedIndexes.length ? Math.max(...claimedIndexes) : -1;
        const remainingFree = Math.max(FREE_LIMIT - (lastClaimIndex + 1), 0);
        const deliveryDate = formatDate(firstNonEmpty((Array.isArray(item2) ? item2 : []).map(x => x.deliveryDate)) || item1.deliveryDate || '');
        const freeUntil = calculateFreeUntil(deliveryDate);
        const freeStatus = remainingFree > 0 && isDateStillFree(freeUntil) ? 'FREE' : 'PAID';

        return { remainingFree, freeUntil: freeUntil || '-', freeStatus };
    }

    function applyFreeServiceSummary(row, item2, item1 = {}) {
        const summary = calculateFreeServiceSummary(item2, item1);
        row.remainingFree = summary.remainingFree;
        row.freeUntil = summary.freeUntil;
        row.freeStatus = summary.freeStatus;
        return row;
    }

    function calculateFreeUntil(deliveryDate) {
        const date = parseDisplayDate(deliveryDate);
        if (!date) return '';
        return formatDate(getEndOfMonth(date.getFullYear() + 3, date.getMonth()));
    }

    function getEndOfMonth(year, monthIndex) {
        return new Date(year, monthIndex + 1, 0);
    }

    function isDateStillFree(freeUntil) {
        const date = parseDisplayDate(freeUntil);
        if (!date) return false;
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        return today.getTime() <= date.getTime();
    }

    /************************************************************
   * MRA DETAIL RENDERING
   ************************************************************/
    function classifyFreeStatus(mainOperationNo) {
        const operation = String(mainOperationNo ?? '').trim();
        return /^\d+k$/i.test(operation) ? 'FREE SERVICE' : 'NON FREE';
    }

    function getMraFreeSummary(item2) {
        const claims = Array.isArray(item2) ? item2 : [];
        const freeOps = [];
        const nonFreeOps = [];

        for (const claim of claims) {
            const operation = String(claim?.mainOperationNo ?? '').trim();

            if (classifyFreeStatus(operation) === 'FREE SERVICE') {
                freeOps.push(operation || '-');
            } else {
                nonFreeOps.push(operation || '-');
            }
        }

        const claimCount = freeOps.length;

        return {
            totalClaims: claims.length,
            claimCount,
            remainingFree: Math.max(FREE_LIMIT - claimCount, 0),
            freeOps,
            nonFreeOps
        };
    }

