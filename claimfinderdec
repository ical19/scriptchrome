    function updateProgress() {
        const total = queue.length || 0;
        const done = Math.min(currentIndex, total);
        const percent = total ? Math.round((done / total) * 100) : 0;

        const bar = document.getElementById('tmProgressBar');
        const counter = document.getElementById('tmCounter');

        if (bar) bar.style.width = percent + '%';
        if (counter) counter.textContent = `${done} / ${total}`;
        updateProgressMeta(total, done);
        updateListCount();
    }

    function resetProgressMetrics() {
        processStartedAt = Date.now();
        activeVinStartedAt = 0;
        vinDurations = [];
        totalResponseBytes = 0;
        totalResponseRequests = 0;
        stopProgressTimer();
        updateProgressMeta(queue.length || 0, currentIndex || 0);
    }

    function startProgressTimer() {
        stopProgressTimer();
        progressTimerId = window.setInterval(updateProgress, 1000);
    }

    function stopProgressTimer() {
        if (!progressTimerId) return;
        window.clearInterval(progressTimerId);
        progressTimerId = null;
    }

    function updateProgressMeta(total, done) {
        const etaEl = document.getElementById('tmProgressEta');
        const sizeEl = document.getElementById('tmProgressSize');

        if (etaEl) {
            etaEl.textContent = buildProgressEstimateText(total, done);
        }

        if (sizeEl) {
            sizeEl.textContent = `Data dimuat: ${formatBytes(totalResponseBytes)} (${totalResponseRequests} request)`;
        }
    }

    function buildProgressEstimateText(total, done) {
        if (!total) return 'Estimasi: -';

        const elapsedMs = processStartedAt ? Math.max(Date.now() - processStartedAt, 0) : 0;
        const averageMs = getCurrentAverageVinMs();

        if (done >= total) {
            return `Selesai dalam ${formatDuration(elapsedMs)}`;
        }

        if (!averageMs) {
            return `Estimasi: menghitung... (${done}/${total})`;
        }

        const remaining = Math.max(total - done, 0);
        const etaMs = Math.max(Math.round(averageMs * remaining), 0);

        return `Estimasi: ${formatDuration(etaMs)} tersisa | Rata-rata ${formatDuration(averageMs)} / VIN`;
    }

    function getCurrentAverageVinMs() {
        const durations = vinDurations.slice();

        if (activeVinStartedAt) {
            durations.push(Math.max(Date.now() - activeVinStartedAt, 0));
        }

        if (!durations.length) return 0;

        return durations.reduce((sum, value) => sum + value, 0) / durations.length;
    }

    function recordResponseSize(text) {
        totalResponseBytes += getTextByteSize(text);
        totalResponseRequests++;
        updateProgress();
    }

    function getTextByteSize(text) {
        const str = String(text ?? '');

        try {
            return new Blob([str]).size;
        } catch (_) {
            return str.length;
        }
    }

    function formatBytes(bytes) {
        const value = Number(bytes) || 0;

        if (value < 1024) return `${value} B`;
        if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;

        return `${(value / (1024 * 1024)).toFixed(2)} MB`;
    }

    function formatDuration(ms) {
        const totalSeconds = Math.max(0, Math.round((Number(ms) || 0) / 1000));
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;

        if (minutes <= 0) return `${seconds}s`;
        return `${minutes}m ${String(seconds).padStart(2, '0')}s`;
    }

    function updateAuthStatus() {
        const el = document.getElementById('tmAuthStatus');
        if (!el) return;

        if (capturedAuthorization) {
            el.textContent = 'Session/token aktif injected.';
            el.classList.add('tmStatusOk');
            el.classList.remove('tmStatusWarn');
        } else {
            el.textContent = 'Token belum ditemukan.';
            el.classList.add('tmStatusWarn');
            el.classList.remove('tmStatusOk');
        }
    }

    function logTerminal(message, type = 'info') {
        const term = document.getElementById('tmTerminal');
        if (!term) return;

        const time = new Date().toLocaleTimeString();
        const div = document.createElement('div');

        const cls = {
            info: 'tmLogInfo',
            warn: 'tmLogWarn',
            error: 'tmLogErr',
            success: 'tmLogSuccess'
        }[type] || 'tmLogInfo';

        const semanticCls = getLogSemanticClass(message, type);
        div.className = semanticCls ? `${cls} ${semanticCls}` : cls;
        div.textContent = `[${time}] ${message}`;

        term.appendChild(div);
        term.scrollTop = term.scrollHeight;
    }

    function getLogSemanticClass(message, type) {
        const text = String(message || '').toLowerCase();

        if (type === 'error' || text.includes('error') || text.includes('gagal')) {
            return 'tmLogErr';
        }

        if (text.includes('kandidat') || text.includes('split vin berhasil') || text.includes('lookup vds menemukan')) {
            return 'tmLogCandidate';
        }

        if (text.includes('request vin') || text.includes('mencari vin') || text.includes('mulai pencarian') || text.includes('mulai proses')) {
            return 'tmLogSearch';
        }

        return '';
    }

