    function ensureToastHost() {
        let host = document.getElementById('tmClaimToastHost');
        if (host) return host;

        host = document.createElement('div');
        host.id = 'tmClaimToastHost';
        document.documentElement.appendChild(host);

        return host;
    }

    function showToast(message) {
        const host = ensureToastHost();
        const toast = document.createElement('div');

        toast.className = 'tmToast';
        toast.textContent = message;

        host.appendChild(toast);
        requestAnimationFrame(() => {
            toast.classList.add('show');
        });

        window.setTimeout(() => {
            toast.classList.remove('show');
            toast.addEventListener('transitionend', () => toast.remove(), { once: true });
            window.setTimeout(() => toast.remove(), 350);
        }, 2600);
    }

    function attachDummyActionToasts(root) {
        root.querySelectorAll('[data-dummy-action]').forEach(el => {
            const notify = () => {
                const label = el.getAttribute('data-dummy-action') || 'Fitur ini';
                showToast(`${label} masih dalam proses pengembangan.`);
            };

            el.addEventListener('click', notify);
            el.addEventListener('keydown', event => {
                if (event.key !== 'Enter' && event.key !== ' ') return;

                event.preventDefault();
                notify();
            });
        });
    }

    function registerUISlashShortcut() {
        if (window.__tmClaimSlashShortcutBound) return;

        window.__tmClaimSlashShortcutBound = true;
        document.addEventListener('keydown', event => {
            if (event.key !== '/' || event.ctrlKey || event.metaKey || event.altKey) return;

            event.preventDefault();
            toggleTampermonkeyUI();
        }, true);
    }

    function toggleTampermonkeyUI() {
        const panel = document.getElementById('tmClaimPanel');
        if (!panel) return;

        const willHide = !panel.classList.contains('tmUiHidden');

        panel.classList.toggle('tmUiHidden', willHide);
        document.documentElement.classList.toggle('tmClaimUiHidden', willHide);

        showToast(
            willHide
            ? 'Claim finder disembunyikan. Tekan / untuk menampilkan kembali.'
            : 'Claim finder ditampilkan kembali.'
        );
    }

    function getVinInputLines() {
        const input = document.getElementById('tmVinInput')?.value || '';

        return input
            .split(/\r?\n/)
            .map(x => x.trim())
            .filter(Boolean);
    }

    function updateVinBulkCount() {
        const el = document.getElementById('tmVinBulkCount');
        if (!el) return;

        const total = getVinInputLines().length;
        el.textContent = `${total} nomor rangka`;
    }

    function clearListView() {
        if (isRunning) {
            logTerminal('Clear List tidak bisa dilakukan saat proses masih berjalan. Stop atau tunggu selesai terlebih dahulu.', 'warn');
            showToast('Proses masih berjalan. Stop atau tunggu selesai sebelum Clear List.');
            return;
        }

        queue = [];
        retryErrorQueue = [];
        currentIndex = 0;
        mainResults = [];
        detailResults = [];
        summaryResults = [];
        resetProgressMetrics();
        clearTable();
        updateProgress();
        updateListCount();

        const searchInput = document.getElementById('tmResultSearchInput');
        if (searchInput) searchInput.value = '';

        showToast('List view sudah dibersihkan.');
    }

    function clearTerminalLog() {
        const term = document.getElementById('tmTerminal');
        if (term) term.innerHTML = '';

        showToast('Log terminal sudah dibersihkan.');
    }

    async function startPartsSearch() {
        if (isRunning) {
            logTerminal('Proses masih berjalan. Gunakan Pause atau Stop terlebih dahulu.', 'warn');
            return;
        }

        let vinInfo;
        try {
            vinInfo = getVINPartInputInfo();
        } catch (err) {
            logTerminal(`Pencarian WMI/VDS/CD/VIS gagal: ${err.message}`, 'error');
            switchTab('terminal');
            return;
        }

        queue = [vinInfo];
        retryErrorQueue = [];
        mainResults = [];
        detailResults = [];
        summaryResults = [];
        currentIndex = 0;
        shouldStop = false;
        isPaused = false;
        isRunning = true;
        resetProgressMetrics();

        clearTable();
        renderMainResults();
        switchTab('terminal');
        logTerminal(`Mulai pencarian split VIN: ${formatVINInfoSplit(vinInfo)}`, 'success');
        startProgressTimer();
        updateProgress();

        await processQueue();
    }

    function getVINPartInputInfo() {
        const wmi = normalizePartInput('tmWmiInput');
        const vds = normalizePartInput('tmVdsInput');
        const cd = normalizePartInput('tmCdInput');
        const vis = normalizePartInput('tmVisInput');

        if (wmi.length !== 3) {
            throw new Error('WMI wajib 3 karakter.');
        }

        if (vds.length < 4 || vds.length > 6) {
            throw new Error('VDS wajib 4 sampai 6 karakter.');
        }

        if (cd.length > 1) {
            throw new Error('CD maksimal 1 karakter atau kosong.');
        }

        if (vis.length !== 8) {
            throw new Error('VIS wajib 8 karakter.');
        }

        return {
            vin: wmi + vds + cd + vis,
            wmi,
            vds,
            cd,
            vis,
            source: 'manual-parts'
        };
    }

    function normalizePartInput(id) {
        const el = document.getElementById(id);
        return String(el?.value || '')
            .trim()
            .toUpperCase()
            .replace(/[^A-Z0-9]/g, '');
    }

    function filterResultRows() {
        const input = document.getElementById('tmResultSearchInput');
        const tbody = document.getElementById('tmResultBody');
        const needle = String(input?.value || '').trim().toLowerCase();

        if (!tbody) return;

        Array.from(tbody.rows).forEach(row => {
            row.style.display = !needle || row.textContent.toLowerCase().includes(needle) ? '' : 'none';
        });
    }

    function toggleBranchColumns() {
        showBranchColumns = !showBranchColumns;
        updateBranchToggleUI();
        renderMainResults();
    }

    function updateBranchToggleUI() {
        const btn = document.getElementById('tmToggleBranchBtn');
        if (btn) btn.textContent = showBranchColumns ? 'Hide Branch' : 'Show Branch';
        document.querySelectorAll('.tmBranchHeader').forEach(el => {
            el.style.display = showBranchColumns ? '' : 'none';
        });
    }

    function updateListCount() {
        const totalEl = document.getElementById('tmPageCount');
        const successEl = document.getElementById('tmPageSuccessCount');
        const failedEl = document.getElementById('tmPageFailedCount');
        const failedKeys = new Set(retryErrorQueue.map(item => normalizeVIN(item.vin)));
        let failedCount = 0;
        let successCount = 0;

        for (const row of mainResults) {
            const isFailed = row.freeStatus === 'ERROR' || failedKeys.has(normalizeVIN(row.vin));
            if (isFailed) failedCount++;
            else successCount++;
        }

        if (totalEl) totalEl.textContent = String(mainResults.length || 0);
        if (successEl) successEl.textContent = String(successCount);
        if (failedEl) failedEl.textContent = String(failedCount);
    }

    function waitDOMReady() {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', injectUI);
        } else {
            injectUI();
        }
    }

    waitDOMReady();

