            const ddlValues = await requestVinDdl(vin);
            const matchingValues = ddlValues.filter(value => vin.startsWith(vin.substring(0, 3) + value));

            logTerminal(
                matchingValues.length
                ? `Lookup VDS menemukan kandidat: ${matchingValues.join(', ')}.`
          : `Lookup VDS tidak menemukan kandidat yang cocok untuk prefix ${vin.substring(3, 7)}.`,
          matchingValues.length ? 'success' : 'warn'
      );

        for (const value of matchingValues) {
            for (const candidate of buildVINCandidatesFromVDS(vin, value, 'ddl')) {
                add(candidate);
            }
        }
    } catch (err) {
        if (isAuthorizationError(err)) {
            throw err;
        }

        logTerminal(`Lookup VDS gagal: ${err.message}. Coba kandidat lokal.`, 'warn');
