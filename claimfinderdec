                vis: vin.substring(8, 16),
                source: 'local-vds5-no-cd'
            });
        }

        return candidates;
    }

    function buildVINCandidatesFromVDS(vin, vds, source = '') {
        const wmi = vin.substring(0, 3);
        const prefix = wmi + vds;

        if (!vin.startsWith(prefix)) {
            return [];
        }

        const tail = vin.substring(prefix.length);
        const candidates = [];

        if (tail.length === 8) {
            candidates.push({
                vin,
                wmi,
                vds,
                cd: '',
                vis: tail,
                source
            });
        }

        if (tail.length === 9 && vds.length === 5) {
            candidates.push({
                vin,
                wmi,
                vds,
                cd: tail.substring(0, 1),
                vis: tail.substring(1),
                source
            });
        }

        return candidates;
    }

    function hasClaimDetailData(json) {
        const data = json?.data;
        if (!data || typeof data !== 'object' || Array.isArray(data)) return false;

        const item1 = data.item1;
        const item2 = Array.isArray(data.item2) ? data.item2 : [];

        if (item2.length > 0) return true;
        if (!item1 || typeof item1 !== 'object') return false;

        return [
            'modelCode',
            'modelName',
            'wmi',
            'vds',
            'cd',
            'vis',
            'modelSfx',
            'salesCode',
            'franchiseLabel'
        ].some(key => String(item1[key] ?? '').trim());
    }

    function getVINInfoKey(vinInfo) {
        return [
            vinInfo.wmi || '',
            vinInfo.vds || '',
            vinInfo.cd || '',
            vinInfo.vis || ''
        ].join('|').toUpperCase();
